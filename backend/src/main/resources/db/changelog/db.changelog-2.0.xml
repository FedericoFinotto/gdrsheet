<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
       http://www.liquibase.org/xml/ns/dbchangelog
       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Autenticazione e permessi -->

    <changeSet id="100" author="developer">
        <preConditions onFail="MARK_RAN">
            <!-- salta se la colonna è già autogenerata (identity o default da sequence) -->
            <sqlCheck expectedResult="0">
                SELECT count(*) FROM information_schema.columns
                WHERE table_name = 'utente' AND column_name = 'id'
                  AND (column_default IS NOT NULL OR is_identity = 'YES')
            </sqlCheck>
        </preConditions>
        <comment>utente.id autoincrement (per future registrazioni)</comment>
        <addAutoIncrement tableName="utente" columnName="id" columnDataType="integer"/>
    </changeSet>

    <!-- allineamento permessi_party preesistente (vecchia struttura con colonna "tipo") -->

    <changeSet id="104" author="developer">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="permessi_party"/>
                <columnExists tableName="permessi_party" columnName="tipo"/>
                <not>
                    <columnExists tableName="permessi_party" columnName="ruolo"/>
                </not>
            </and>
        </preConditions>
        <comment>rinomina tipo -> ruolo sulla permessi_party preesistente</comment>
        <renameColumn tableName="permessi_party" oldColumnName="tipo" newColumnName="ruolo"/>
    </changeSet>

    <changeSet id="105" author="developer">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="permessi_party"/>
                <not>
                    <columnExists tableName="permessi_party" columnName="ruolo"/>
                </not>
            </and>
        </preConditions>
        <comment>aggiunge ruolo se mancante del tutto</comment>
        <addColumn tableName="permessi_party">
            <column name="ruolo" type="varchar(20)" defaultValue="GIOCATORE">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="106" author="developer">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT count(*) FROM information_schema.columns
                WHERE table_name = 'permessi_party' AND column_name = 'id'
                  AND (column_default IS NOT NULL OR is_identity = 'YES')
            </sqlCheck>
        </preConditions>
        <comment>permessi_party.id autoincrement se la tabella preesistente non lo aveva</comment>
        <addAutoIncrement tableName="permessi_party" columnName="id" columnDataType="integer"/>
    </changeSet>

    <changeSet id="107" author="developer">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="1">
                SELECT CASE WHEN pg_get_serial_sequence('permessi_party', 'id') IS NULL THEN 0 ELSE 1 END
            </sqlCheck>
        </preConditions>
        <comment>allinea la sequence di permessi_party.id al massimo attuale</comment>
        <sql>SELECT setval(pg_get_serial_sequence('permessi_party', 'id'), COALESCE((SELECT max(id) FROM permessi_party), 0) + 1, false)</sql>
    </changeSet>

    <changeSet id="103" author="developer">
        <preConditions onFail="MARK_RAN">
            <!-- esegui solo se esiste una sequence collegata alla colonna -->
            <sqlCheck expectedResult="1">
                SELECT CASE WHEN pg_get_serial_sequence('utente', 'id') IS NULL THEN 0 ELSE 1 END
            </sqlCheck>
        </preConditions>
        <comment>allinea la sequence di utente.id al massimo attuale</comment>
        <sql>SELECT setval(pg_get_serial_sequence('utente', 'id'), COALESCE((SELECT max(id) FROM utente), 0) + 1, false)</sql>
    </changeSet>

    <changeSet id="101" author="developer">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="permessi_personaggi" columnName="permesso"/>
            </not>
        </preConditions>
        <comment>tipo permesso sul personaggio: PROPRIETARIO | VISUALIZZATORE</comment>
        <addColumn tableName="permessi_personaggi">
            <column name="permesso" type="varchar(20)" defaultValue="PROPRIETARIO">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="102" author="developer">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="permessi_party"/>
            </not>
        </preConditions>
        <comment>relazione utente-party con ruolo: MASTER | GIOCATORE</comment>
        <createTable tableName="permessi_party">
            <column name="id" type="integer" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="id_utente" type="integer">
                <constraints nullable="false"
                             foreignKeyName="fk_permessi_party_utente"
                             references="utente(id)"/>
            </column>
            <column name="id_party" type="integer">
                <constraints nullable="false"
                             foreignKeyName="fk_permessi_party_party"
                             references="party(id)"/>
            </column>
            <column name="ruolo" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="permessi_party"
                             columnNames="id_utente, id_party"
                             constraintName="uq_permessi_party_utente_party"/>
    </changeSet>

    <!-- stat_value: id autogenerato (serve per creare le stat mancanti all'apertura del personaggio) -->

    <changeSet id="108" author="developer">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT count(*) FROM information_schema.columns
                WHERE table_name = 'stat_value' AND column_name = 'id'
                  AND (column_default IS NOT NULL OR is_identity = 'YES')
            </sqlCheck>
        </preConditions>
        <comment>stat_value.id autoincrement</comment>
        <addAutoIncrement tableName="stat_value" columnName="id" columnDataType="integer"/>
    </changeSet>

    <changeSet id="109" author="developer">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="1">
                SELECT CASE WHEN pg_get_serial_sequence('stat_value', 'id') IS NULL THEN 0 ELSE 1 END
            </sqlCheck>
        </preConditions>
        <comment>allinea la sequence di stat_value.id al massimo attuale</comment>
        <sql>SELECT setval(pg_get_serial_sequence('stat_value', 'id'), COALESCE((SELECT max(id) FROM stat_value), 0) + 1, false)</sql>
    </changeSet>

    <!-- permessi_personaggi.tipo legacy: sostituita da permesso, va resa nullable -->

    <changeSet id="113" author="developer">
        <preConditions onFail="MARK_RAN">
            <and>
                <columnExists tableName="permessi_personaggi" columnName="tipo"/>
                <sqlCheck expectedResult="0">
                    SELECT count(*) FROM information_schema.columns
                    WHERE table_name = 'permessi_personaggi' AND column_name = 'tipo' AND is_nullable = 'YES'
                </sqlCheck>
            </and>
        </preConditions>
        <comment>permessi_personaggi.tipo (legacy) reso nullable</comment>
        <dropNotNullConstraint tableName="permessi_personaggi" columnName="tipo" columnDataType="varchar"/>
    </changeSet>

    <!-- personaggio.id autoincrement (per la creazione di personaggi dall'app) -->

    <changeSet id="111" author="developer">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT count(*) FROM information_schema.columns
                WHERE table_name = 'personaggio' AND column_name = 'id'
                  AND (column_default IS NOT NULL OR is_identity = 'YES')
            </sqlCheck>
        </preConditions>
        <comment>personaggio.id autoincrement</comment>
        <addAutoIncrement tableName="personaggio" columnName="id" columnDataType="integer"/>
    </changeSet>

    <changeSet id="112" author="developer">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="1">
                SELECT CASE WHEN pg_get_serial_sequence('personaggio', 'id') IS NULL THEN 0 ELSE 1 END
            </sqlCheck>
        </preConditions>
        <comment>allinea la sequence di personaggio.id al massimo attuale</comment>
        <sql>SELECT setval(pg_get_serial_sequence('personaggio', 'id'), COALESCE((SELECT max(id) FROM personaggio), 0) + 1, false)</sql>
    </changeSet>

    <!-- avanzamento.id autoincrement (per l'editor delle classi) -->

    <changeSet id="114" author="developer">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT count(*) FROM information_schema.columns
                WHERE table_name = 'avanzamento' AND column_name = 'id'
                  AND (column_default IS NOT NULL OR is_identity = 'YES')
            </sqlCheck>
        </preConditions>
        <comment>avanzamento.id autoincrement</comment>
        <addAutoIncrement tableName="avanzamento" columnName="id" columnDataType="integer"/>
    </changeSet>

    <changeSet id="115" author="developer">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="1">
                SELECT CASE WHEN pg_get_serial_sequence('avanzamento', 'id') IS NULL THEN 0 ELSE 1 END
            </sqlCheck>
        </preConditions>
        <comment>allinea la sequence di avanzamento.id al massimo attuale</comment>
        <sql>SELECT setval(pg_get_serial_sequence('avanzamento', 'id'), COALESCE((SELECT max(id) FROM avanzamento), 0) + 1, false)</sql>
    </changeSet>

    <!-- Soldi: stats MR/MA/MO/MP (i valori vivono come modificatori sugli item dei personaggi) -->

    <!-- modificatori: id_sorgente per distinguere le copie da grant (di classe)
         dai modificatori liberi aggiunti a mano su un livello -->

    <changeSet id="116" author="developer">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="modificatori" columnName="id_sorgente"/>
            </not>
        </preConditions>
        <comment>modificatori.id_sorgente: id del modificatore sorgente per le copie da grant</comment>
        <addColumn tableName="modificatori">
            <column name="id_sorgente" type="integer"/>
        </addColumn>
    </changeSet>

    <changeSet id="110" author="developer">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT count(*) FROM stats WHERE id IN ('MR', 'MA', 'MO', 'MP')
            </sqlCheck>
        </preConditions>
        <comment>stat monete: rame, argento, oro, platino</comment>
        <insert tableName="stats">
            <column name="id" value="MR"/>
            <column name="tipo" value="COUNT"/>
            <column name="label" value="Monete di Rame"/>
        </insert>
        <insert tableName="stats">
            <column name="id" value="MA"/>
            <column name="tipo" value="COUNT"/>
            <column name="label" value="Monete d'Argento"/>
        </insert>
        <insert tableName="stats">
            <column name="id" value="MO"/>
            <column name="tipo" value="COUNT"/>
            <column name="label" value="Monete d'Oro"/>
        </insert>
        <insert tableName="stats">
            <column name="id" value="MP"/>
            <column name="tipo" value="COUNT"/>
            <column name="label" value="Monete di Platino"/>
        </insert>
    </changeSet>

    <changeSet id="117" author="developer">
        <addColumn tableName="item_label">
            <column name="id_personaggio" type="bigint">
                <constraints nullable="true"
                             foreignKeyName="fk_item_label_personaggio"
                             references="personaggio(id)"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="118" author="developer">
        <addColumn tableName="collegamento">
            <column name="qty" type="int">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="119" author="developer">
        <addColumn tableName="avanzamento">
            <column name="qty" type="int">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="120" author="developer">
        <addColumn tableName="collegamento">
            <column name="scelta" type="varchar(32)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="121" author="developer">
        <addColumn tableName="collegamento">
            <column name="formula_qty" type="varchar(64)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="122" author="developer">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT count(*) FROM stats WHERE id = 'ABTUTTE'
            </sqlCheck>
        </preConditions>
        <comment>stat fittizia "Tutte le abilità": bersaglio di un CAMBIA_CARATTERISTICA globale</comment>
        <insert tableName="stats">
            <column name="id" value="ABTUTTE"/>
            <column name="tipo" value="AB"/>
            <column name="label" value="Tutte le abilità"/>
        </insert>
    </changeSet>

    <changeSet id="124" author="developer">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT count(*) FROM stats WHERE id = 'TSTUTTI'
            </sqlCheck>
        </preConditions>
        <comment>stat fittizia "Tutti i tiri salvezza": bersaglio di un CAMBIA_CARATTERISTICA globale sui TS</comment>
        <insert tableName="stats">
            <column name="id" value="TSTUTTI"/>
            <column name="tipo" value="TS"/>
            <column name="label" value="Tutti i tiri salvezza"/>
        </insert>
    </changeSet>

    <changeSet id="123" author="developer">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="gruppo"/>
            </not>
        </preConditions>
        <comment>gruppo di personaggi in un party (appartenenza via personaggio_label GRUPPO)</comment>
        <createTable tableName="gruppo">
            <column name="id" type="integer" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="party_id" type="integer">
                <constraints nullable="false"
                             foreignKeyName="fk_gruppo_party"
                             references="party(id)"/>
            </column>
            <column name="nome" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="125" author="developer">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="cache_entry"/>
            </not>
        </preConditions>
        <comment>cache generica chiave/valore (JSON) per dati calcolati costosi legati a un personaggio, con scadenza esplicita e invalidazione attiva (vedi PersonaggioCacheService)</comment>
        <createTable tableName="cache_entry">
            <column name="cache_key" type="varchar(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="valore" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="dt_scadenza" type="timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
